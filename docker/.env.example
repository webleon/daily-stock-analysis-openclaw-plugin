# Daily Stock Analysis - Environment Configuration
# Copy this file to .env and fill in your values

# ============================================================================
# Stock List (Required)
# ============================================================================
STOCK_LIST=600519,hk00700,AAPL,TSLA

# ============================================================================
# AI Model Configuration (At least one required)
# ============================================================================

# Option 1: AIHubMix (Recommended - one key for all models)
# AIHUBMIX_KEY=your_aihubmix_key_here

# Option 2: Google Gemini (Free tier available)
# GEMINI_API_KEY=your_gemini_key_here

# Option 3: Anthropic Claude
# ANTHROPIC_API_KEY=your_anthropic_key_here
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Option 4: OpenAI Compatible (DeepSeek, Qwen, etc.)
# OPENAI_API_KEY=your_openai_key_here
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# OPENAI_MODEL=deepseek-chat

# ============================================================================
# Notification Channels (Optional - at least one for push notifications)
# ============================================================================

# Telegram
# TELEGRAM_BOT_TOKEN=your_bot_token
# TELEGRAM_CHAT_ID=your_chat_id

# Enterprise WeChat
# WECHAT_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxx

# Feishu/Lark
# FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxx

# Email
# EMAIL_SENDER=your_email@gmail.com
# EMAIL_PASSWORD=your_app_password
# EMAIL_RECEIVERS=recipient@example.com

# ============================================================================
# Optional Features
# ============================================================================

# News Search (Recommended for better analysis)
# TAVILY_API_KEYS=your_tavily_key_here

# Trading Day Check (Default: true)
# TRADING_DAY_CHECK_ENABLED=true

# Analysis Schedule (GitHub Actions only, ignored in Docker)
# SCHEDULE='0 10 * * 1-5'  # 10:00 AM on weekdays

# ============================================================================
# Advanced Configuration (Optional)
# ============================================================================

# Report Language: zh (Chinese) or en (English)
# REPORT_LANGUAGE=zh

# Report Type: simple, full, brief
# REPORT_TYPE=full

# Agent Mode: true/false
# AGENT_MODE=false

# Web UI Authentication
# ADMIN_AUTH_ENABLED=false
